datasource db {
  provider = "mysql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes", "views"]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum TableStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  MAINTENANCE
}

enum RestaurantStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  CLOSED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  REVIEW_RECEIVED
  RESTAURANT_APPROVED
  RESTAURANT_SUSPENDED
  GENERAL
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  first_name String
  last_name  String
  phone      String?
  avatar_url String?
  role       Role     @default(CUSTOMER)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  customer        Customer?
  restaurant_owner RestaurantOwner?
  admin            Admin?
  notifications    Notification[]
  refresh_tokens   RefreshToken[]

  @@fulltext([first_name, last_name, email])
}

// ─────────────────────────────────────────────
// ROLES
// ─────────────────────────────────────────────

model Customer {
  id                  Int      @id @default(autoincrement())
  user_id             Int      @unique
  preferred_language  String?  @default("en")
  dietary_preferences String?  @db.Text
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  bookings Booking[]
  reviews  Review[]
  favourites FavouriteRestaurant[]
}

model RestaurantOwner {
  id         Int      @id @default(autoincrement())
  user_id    Int      @unique
  bio        String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user        User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  restaurants Restaurant[]
}

model Admin {
  id         Int      @id @default(autoincrement())
  user_id    Int      @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  audit_logs      AuditLog[]
  restaurant_approvals RestaurantApproval[]
}

// ─────────────────────────────────────────────
// RESTAURANT
// ─────────────────────────────────────────────

model Restaurant {
  id                  Int              @id @default(autoincrement())
  owner_id            Int
  name                String
  slug                String           @unique
  description         String?          @db.Text
  cuisine_type        String?
  address             String
  city                String
  state               String?
  country             String
  postal_code         String?
  latitude            Decimal?         @db.Decimal(10, 8)
  longitude           Decimal?         @db.Decimal(11, 8)
  phone               String?
  email               String?
  website             String?
  cover_image_url     String?
  status              RestaurantStatus @default(PENDING_APPROVAL)
  average_rating      Decimal          @default(0) @db.Decimal(3, 2)
  total_reviews       Int              @default(0)
  min_booking_notice  Int              @default(60)   // minutes in advance
  max_booking_days    Int              @default(30)   // days ahead
  cancellation_hours  Int              @default(24)   // hours before booking
  deposit_required    Boolean          @default(false)
  deposit_amount      Decimal?         @db.Decimal(10, 2)
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  owner             RestaurantOwner       @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  tables            Table[]
  operating_hours   OperatingHour[]
  special_closures  SpecialClosure[]
  bookings          Booking[]
  reviews           Review[]
  gallery_images    RestaurantImage[]
  tags              RestaurantTag[]
  amenities         RestaurantAmenity[]
  approval          RestaurantApproval?
  favourited_by     FavouriteRestaurant[]

  @@fulltext([name, description, cuisine_type, city])
}

model RestaurantApproval {
  id            Int      @id @default(autoincrement())
  restaurant_id Int      @unique
  admin_id      Int
  approved      Boolean
  notes         String?  @db.Text
  reviewed_at   DateTime @default(now())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  admin      Admin      @relation(fields: [admin_id], references: [id])
}

model RestaurantImage {
  id            Int      @id @default(autoincrement())
  restaurant_id Int
  url           String
  caption       String?
  sort_order    Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
}

model Tag {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  restaurants RestaurantTag[]
}

model RestaurantTag {
  id            Int      @id @default(autoincrement())
  restaurant_id Int
  tag_id        Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@unique([restaurant_id, tag_id])
}

model Amenity {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  icon       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  restaurants RestaurantAmenity[]
}

model RestaurantAmenity {
  id            Int      @id @default(autoincrement())
  restaurant_id Int
  amenity_id    Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  amenity    Amenity    @relation(fields: [amenity_id], references: [id], onDelete: Cascade)

  @@unique([restaurant_id, amenity_id])
}

model FavouriteRestaurant {
  id            Int      @id @default(autoincrement())
  customer_id   Int
  restaurant_id Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  customer   Customer   @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@unique([customer_id, restaurant_id])
}

// ─────────────────────────────────────────────
// OPERATING HOURS & CLOSURES
// ─────────────────────────────────────────────

model OperatingHour {
  id            Int       @id @default(autoincrement())
  restaurant_id Int
  day_of_week   DayOfWeek
  open_time     String    // "HH:MM" 24h format
  close_time    String
  is_closed     Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@unique([restaurant_id, day_of_week])
}

model SpecialClosure {
  id            Int      @id @default(autoincrement())
  restaurant_id Int
  date          DateTime @db.Date
  reason        String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@unique([restaurant_id, date])
}

// ─────────────────────────────────────────────
// TABLE
// ─────────────────────────────────────────────

model Table {
  id            Int         @id @default(autoincrement())
  restaurant_id Int
  table_number  String
  capacity      Int
  floor         String?
  status        TableStatus @default(AVAILABLE)
  is_active     Boolean     @default(true)
  description   String?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  restaurant     Restaurant      @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  booking_tables BookingTable[]

  @@unique([restaurant_id, table_number])
}

// ─────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────

model Booking {
  id               Int           @id @default(autoincrement())
  reference_code   String        @unique @default(cuid())
  customer_id      Int
  restaurant_id    Int
  booking_date     DateTime      @db.Date
  booking_time     String        // "HH:MM"
  duration_minutes Int           @default(90)
  party_size       Int
  status           BookingStatus @default(PENDING)
  special_requests String?       @db.Text
  internal_notes   String?       @db.Text
  confirmed_at     DateTime?
  cancelled_at     DateTime?
  cancellation_reason String?    @db.Text
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  customer       Customer       @relation(fields: [customer_id], references: [id])
  restaurant     Restaurant     @relation(fields: [restaurant_id], references: [id])
  booking_tables BookingTable[]
  payment        Payment?
  review         Review?

  @@index([restaurant_id, booking_date, status])
  @@index([customer_id, booking_date])
}

model BookingTable {
  id         Int      @id @default(autoincrement())
  booking_id Int
  table_id   Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  table   Table   @relation(fields: [table_id], references: [id])

  @@unique([booking_id, table_id])
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id                  Int           @id @default(autoincrement())
  booking_id          Int           @unique
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("USD")
  status              PaymentStatus @default(PENDING)
  payment_method      String?
  transaction_id      String?       @unique
  paid_at             DateTime?
  refunded_at         DateTime?
  refund_amount       Decimal?      @db.Decimal(10, 2)
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────

model Review {
  id            Int      @id @default(autoincrement())
  booking_id    Int      @unique
  customer_id   Int
  restaurant_id Int
  rating        Int      // 1–5
  food_rating   Int?
  service_rating Int?
  ambiance_rating Int?
  comment       String?  @db.Text
  is_published  Boolean  @default(true)
  owner_reply   String?  @db.Text
  replied_at    DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  booking    Booking    @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  customer   Customer   @relation(fields: [customer_id], references: [id])
  restaurant Restaurant @relation(fields: [restaurant_id], references: [id])

  @@index([restaurant_id, is_published])
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id         Int              @id @default(autoincrement())
  user_id    Int
  type       NotificationType
  title      String
  message    String           @db.Text
  data       Json?            // extra payload (booking_id, etc.)
  is_read    Boolean          @default(false)
  read_at    DateTime?
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model RefreshToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique @db.VarChar(512)
  expires_at DateTime
  revoked    Boolean  @default(false)
  ip_address String?
  user_agent String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id          Int      @id @default(autoincrement())
  admin_id    Int
  action      String
  entity      String   // e.g. "Restaurant", "Booking", "User"
  entity_id   Int
  before_data Json?
  after_data  Json?
  ip_address  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  admin Admin @relation(fields: [admin_id], references: [id])

  @@index([entity, entity_id])
}
